# MBTI-PRO 生产环境变量
# 复制此文件为 .env 并填入实际值，或在 Render/Vercel 面板中直接设置

# 必填：火山引擎 API Key（图片生成用，日常运行不需要）
VOLCENGINE_API_KEY=ark-xxxxxxxxxx

# 可选：生产域名（CORS 白名单）
CLIENT_ORIGIN=https://mbti-pro.vercel.app

# 以下均已有默认值，通常无需修改
# VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com
# VOLCENGINE_IMAGE_MODEL=doubao-seedream-5-0-lite-260128
# PORT=3001
