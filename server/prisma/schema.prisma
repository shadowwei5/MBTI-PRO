generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Question {
  id            Int     @id
  text          String  // objective question text (likert uses textLeft/textRight)
  textLeft      String? // bipolar left-pole statement (likert only)
  textRight     String? // bipolar right-pole statement (likert only)
  dimension     String  // E_I, S_N, T_F, P_J
  type          String  // likert, objective
  options       String  // JSON array
  correctAnswer String? // only for objective type
  sortOrder     Int     @default(0)

  @@index([dimension])
  @@index([type])
}

model PersonalityType {
  code            String @id // e.g. "ENTJ", "ABCA"
  name            String // Chinese descriptive name
  isTraditional   Boolean @default(false) // true for classic 16 types
  overview        String // 1-2 paragraph personality overview
  strengths       String // JSON array of 3-5 strengths
  growthAreas     String // JSON array of 3-5 growth suggestions
  careers         String // JSON array of 5-8 recommended careers
  suitableFields  String // JSON array of suitable work fields
  population      String? // e.g. "约 5.6%"
  celebrities     String? // JSON array of famous people names
  // Dimension-specific module descriptions (3 per dimension × 4 = 12 modules)
  eiModule        String?
  snModule        String?
  tfModule        String?
  pjModule        String?
  // Deep report content (付费解锁)
  deepOverview    String?  // 深度概览 500+字
  compatibility   String?  // 相处兼容性 JSON
  traitTags       String?  // 网络特质标签 JSON ["药水姐","逻辑鬼才"]

  @@index([isTraditional])
}

model TestRecord {
  id              String   @id @default(cuid())
  typeCode        String   // resulting 4-char type code
  scores          String   // JSON: {"E_I":15,"S_N":-8,"T_F":32,"P_J":5}
  chars           String   // JSON: {"E_I":"E","S_N":"B","T_F":"T","P_J":"D"}
  answers         String   // JSON: {"1":"A","2":"B",...}
  duration        Int      // seconds spent on test
  dimAnswered     String?  // JSON: {"E_I":23,"S_N":25,"T_F":20,"P_J":24} each dimension answered count
  dimTotals       String?  // JSON: {"E_I":25,"S_N":25,"T_F":25,"P_J":25} each dimension total
  confidence      Int?     // overall confidence 0-100 (min of 4 dimensions)
  deviceInfo      String?  // JSON: {os,browser,screen,language}
  utmSource       String?  // utm_source from URL
  utmMedium       String?  // utm_medium
  utmCampaign     String?  // utm_campaign
  questionTimings String?  // JSON: {"1":5.2,"2":3.1,...} seconds per question
  abandonStep     Int?     // 最后答到的题号(如未完成)
  createdAt       DateTime @default(now())

  @@index([typeCode])
  @@index([createdAt])
  @@index([confidence])
}

model UserFeedback {
  id            String   @id @default(uuid())
  recordId      String?  // 关联的测试记录ID
  userType      String   // 用户自己的人格类型
  likedType     String   // 相处愉快的类型
  dislikedType  String   // 相处痛苦的类型
  createdAt     DateTime @default(now())

  @@index([userType])
  @@index([likedType])
  @@index([dislikedType])
  @@index([recordId])
}

model PaymentRecord {
  typeCode String   @id
  paid     Boolean  @default(false)
  paidAt   DateTime?
  createdAt DateTime @default(now())
}

model UserEmail {
  id        String   @id @default(uuid())
  email     String   @unique
  typeCode  String?  // 关联的人格类型(如有)
  source    String   @default("paywall") // paywall | footer | quiz
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}
